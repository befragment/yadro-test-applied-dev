PORT=...

POSTGRES_HOST=... # name of service in docker-compose.yaml
POSTGRES_PORT=...
POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=...
POSTGRES_SSLMODE=disable

LOG_LEVEL=info

GOOSE_DRIVER=postgres
GOOSE_DBSTRING={GOOSE_DRIVER}://{POSTGRES_USER}:{POSTGRES_PASSWORD}@{POSTGRES_HOST}:{POSTGRES_PORT}/{POSTGRES_DB}