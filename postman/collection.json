{
  "info": {
    "_postman_id": "yadro-log-parser-api-v1",
    "name": "Yadro Log Parser API",
    "description": "API tests for the Yadro log parser service.\n\nWorkflow:\n1. Run **Parse** to upload an archive — `log_id` and `node_id` are saved automatically.\n2. Use the saved variables in **Log**, **Topology**, **Node**, **Port** requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "archive_path",
      "value": "/data/test.zip",
      "description": "Absolute path to the .zip archive on the server",
      "type": "string"
    },
    {
      "key": "log_id",
      "value": "1",
      "description": "Set automatically after a successful Parse request",
      "type": "string"
    },
    {
      "key": "node_id",
      "value": "1",
      "description": "Set automatically after a successful Get Topology request",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Ping",
      "item": [
        {
          "name": "Ping – health check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/ping",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ping"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response body contains pong', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('message');",
                  "    pm.expect(json.message).to.eql('pong');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Parse",
      "item": [
        {
          "name": "Parse – success (saves log_id)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/parse/?path={{archive_path}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parse", ""],
              "query": [
                {
                  "key": "path",
                  "value": "{{archive_path}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response contains numeric log_id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('log_id');",
                  "    pm.expect(json.log_id).to.be.a('number');",
                  "    pm.expect(json.log_id).to.be.above(0);",
                  "    pm.collectionVariables.set('log_id', json.log_id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Parse – 400 missing path param",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/parse/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "parse", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message: path is required', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('error');",
                  "    pm.expect(json.error).to.eql('path is required');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Parse – 404 archive file not found",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/parse/?path=/nonexistent/archive.zip",
