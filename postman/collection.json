                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response contains topology fields', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('log_id');",
                  "    pm.expect(json).to.have.property('hosts');",
                  "    pm.expect(json).to.have.property('switches');",
                  "    pm.expect(json.hosts).to.be.an('array');",
                  "    pm.expect(json.switches).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Save first available node_id', function () {",
                  "    const json = pm.response.json();",
                  "    const allNodes = [...(json.hosts || []), ...(json.switches || [])];",
                  "    if (allNodes.length > 0) {",
                  "        pm.collectionVariables.set('node_id', allNodes[0].id);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
