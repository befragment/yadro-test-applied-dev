          "name": "Get ports – success",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/port/{{node_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "port", "{{node_id}}"]
