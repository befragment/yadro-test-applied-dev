                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response is an array of ports', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each port has required fields', function () {",
                  "    const json = pm.response.json();",
                  "    json.forEach(function (port) {",
                  "        pm.expect(port).to.have.property('node_guid');",
                  "        pm.expect(port).to.have.property('port_guid');",
                  "        pm.expect(port).to.have.property('port_num');",
                  "        pm.expect(port).to.have.property('lid');",
                  "        pm.expect(port).to.have.property('port_state');",
                  "        pm.expect(port).to.have.property('port_phy_state');",
                  "        pm.expect(port).to.have.property('link_width_active');",
                  "        pm.expect(port).to.have.property('link_speed_active');",
                  "        pm.expect(port).to.have.property('link_round_trip_latency');",
                  "    });",
                  "});"
                ]
              }
            }
